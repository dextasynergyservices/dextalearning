
# ── DATABASE ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://dextalearning:secret@localhost:5432/dextalearning"
# Disposable DB for integration tests (Phase C) — create once with:
#   docker compose exec postgres createdb -U dextalearning dextalearning_test
TEST_DATABASE_URL="postgresql://dextalearning:secret@localhost:5432/dextalearning_test"

# ── REDIS ────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── CLOUDFLARE R2 ────────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="dextalearning-content"
R2_ENDPOINT="https://{account_id}.r2.cloudflarestorage.com"

# ── AUTH (Better Auth) ───────────────────────────────────────────
BETTER_AUTH_SECRET="your-better-auth-secret-minimum-32-characters"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-secret"

# ── AI ───────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ── EMAIL ────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="DextaLearning <noreply@dextalearning.com>"

# ── SMS / WHATSAPP ───────────────────────────────────────────────
TERMII_API_KEY="your-termii-api-key"
TERMII_SENDER_ID="DextaLearning"
TERMII_BASE_URL="https://api.ng.termii.com/api"

# ── PAYMENTS ─────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── SEARCH ───────────────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="devkey"

# ── PUSH NOTIFICATIONS ───────────────────────────────────────────
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:tech@dextalearning.com"
FCM_SERVER_KEY="your-fcm-server-key"

# ── BOT PROTECTION ───────────────────────────────────────────────
CLOUDFLARE_TURNSTILE_SECRET="your-turnstile-secret"

# ── MONITORING ───────────────────────────────────────────────────
SENTRY_DSN="https://...@sentry.io/..."
POSTHOG_API_KEY="phc_..."

# ── APP ──────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
ADMIN_API_KEY="your-admin-api-key"
API_VERSION="v1"

# ── MEDIA LIMITS ─────────────────────────────────────────────────
MEDIA_MAX_DURATION_SECONDS=900
VIDEO_PRESIGNED_URL_EXPIRY_SECONDS=7200
AUDIO_PRESIGNED_URL_EXPIRY_SECONDS=7200
CAPTION_PRESIGNED_URL_EXPIRY_SECONDS=7200
PROCTORING_SCREENSHOT_MAX_SIZE_KB=100

# ── REVENUE SPLIT ────────────────────────────────────────────────
INSTRUCTOR_REVENUE_SHARE_PCT=90
