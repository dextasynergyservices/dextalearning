
# ── DATABASE ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://dextalearning:secret@localhost:5432/dextalearning"
# Disposable DB for integration tests (Phase C) — create once with:
#   docker compose exec postgres createdb -U dextalearning dextalearning_test
TEST_DATABASE_URL="postgresql://dextalearning:secret@localhost:5432/dextalearning_test"

# ── REDIS ────────────────────────────────────────────────────────
# Low-frequency TTL caches ONLY (leaderboard, AI responses, settings, quota) via
# CachePort. Serverless/metered (Upstash free 500k/mo) is fine — these are cheap.
# Sessions + rate-limit counters do NOT use this on a single instance.
REDIS_URL="redis://localhost:6379"
#
# Multi-instance ONLY. Puts the HOT per-request paths (global throttler counters,
# Better Auth sessions/rate-limit, Socket.io chat fan-out) on Redis so replicas
# share state. Leave UNSET on the single free-tier instance — those run in memory
# = zero Redis commands/request (a per-request Redis op blows the 500k/mo cap).
# REDIS_DISTRIBUTED="true"
#
# Background queue (media encoding + payout/earn-back workers). UNSET (free tier)
# ⇒ the in-process InlineQueueAdapter runs jobs in this instance with ZERO Redis.
# Set this to a small PERSISTENT (unmetered) Redis to switch to durable BullMQ —
# NEVER the metered Upstash, since BullMQ's blocking workers poll continuously.
# Same producer/worker code either way; this is a pure deploy-time flip.
# QUEUE_REDIS_URL="redis://persistent-host:6379"
#
# Set "false" to disable the in-process @Cron sweeps (reminders/coach/dropoff/
# earn-back) — e.g. on scale-to-zero, where they fire unreliably anyway.
# SCHEDULERS_ENABLED="false"

# ── CLOUDFLARE R2 ────────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="dextalearning-content"
R2_ENDPOINT="https://{account_id}.r2.cloudflarestorage.com"

# ── AUTH (Better Auth) ───────────────────────────────────────────
BETTER_AUTH_SECRET="your-better-auth-secret-minimum-32-characters"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-secret"

# ── AI ───────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ── EMAIL ────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="DextaLearning <noreply@dextalearning.com>"

# ── SMS / WHATSAPP ───────────────────────────────────────────────
TERMII_API_KEY="your-termii-api-key"
TERMII_SENDER_ID="DextaLearning"
TERMII_BASE_URL="https://api.ng.termii.com/api"

# ── PAYMENTS ─────────────────────────────────────────────────────
# Leave a provider's keys blank to use the built-in Fake gateway (dev/e2e): the
# whole checkout → webhook → settlement → payout flow runs with no live money.
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Signature the Fake gateway expects on simulated webhooks (dev/e2e only).
FAKE_GATEWAY_SECRET="fake-gateway-secret"

# ── SEARCH ───────────────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="devkey"

# ── PUSH NOTIFICATIONS ───────────────────────────────────────────
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:tech@dextalearning.com"
FCM_SERVER_KEY="your-fcm-server-key"

# ── BOT PROTECTION ───────────────────────────────────────────────
CLOUDFLARE_TURNSTILE_SECRET="your-turnstile-secret"

# ── APP ──────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
ADMIN_API_KEY="your-admin-api-key"
API_VERSION="v1"

# ── MEDIA LIMITS ─────────────────────────────────────────────────
MEDIA_MAX_DURATION_SECONDS=900
VIDEO_PRESIGNED_URL_EXPIRY_SECONDS=7200
AUDIO_PRESIGNED_URL_EXPIRY_SECONDS=7200
CAPTION_PRESIGNED_URL_EXPIRY_SECONDS=7200
PROCTORING_SCREENSHOT_MAX_SIZE_KB=100

# ── REVENUE SPLIT ────────────────────────────────────────────────
INSTRUCTOR_REVENUE_SHARE_PCT=90

# ── Observability (§15) — all optional; blank = disabled, zero network ──────
# Sentry: the API has its OWN project (separate DSN from the web app).
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1
# PostHog: the SAME project key as the web app (one product = one event stream).
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
# Logging: set LOG_JSON=1 to force raw JSON lines outside production.
LOG_LEVEL=info

# Password the external scheduler presents to POST /api/v1/internal/sweeps/*.
# Generate with: openssl rand -hex 32
# Leave EMPTY to keep the sweep endpoints closed to everyone (the safe default).
CRON_SECRET=
